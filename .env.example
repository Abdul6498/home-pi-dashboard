# OpenWeather API key (or compatible provider)
WEATHER_API_KEY=

# Optional override for config location
# HH_CONFIG=config/settings.toml

# Temporary adhan playback test.
# Uncomment only when you want to test adhan immediately after app startup,
# then remove/comment these lines again for normal use.
# HH_TEST_ADHAN_AFTER_SECONDS=15
# HH_TEST_ADHAN_SALAH=Fajr

# Laptop-only test helpers.
# Pick which display should show the fullscreen dashboard.
# This is 1-based, so 4 means "fourth screen".
# HH_TEST_SCREEN=4

# Manual salah progress test controls for the new prayer theme.
# Valid progress names: Qiyam, Ruku, I'tidal, Sajda, Jalsa, Sajda2, Taslim
# HH_TEST_SALAH_PROGRESS_NAME=Jalsa
# HH_TEST_RAKAT_NUMBER=2
